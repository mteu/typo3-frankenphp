parameters:
  level: 6

  paths:
    - Classes
    - Configuration
    - Tests

  # PHPStan looks for vendor/autoload.php next to phpstan.neon by default.
  # Our dev install autoload lives in Build/vendor; both bootstrapFiles
  # (executes the file) and scanDirectories (walks PSR-4 paths for class
  # discovery) are needed for class resolution to succeed.
  bootstrapFiles:
    - Build/vendor/autoload.php
  scanDirectories:
    - Build/vendor/typo3/cms-core/Classes

  # Don't error on unmatched ignored errors during baseline rebuilds.
  reportUnmatchedIgnoredErrors: false
  ignoreErrors:
    -
      identifier: missingType.iterableValue
#includes:
#  - phpstan-baseline.neon
