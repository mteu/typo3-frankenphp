parameters:
  level: 6

  paths:
    - Classes
    - Configuration
    - Tests

  # Root vendor/autoload.php is enough — composer/composer, typo3/cms-core,
  # typo3/cms-backend are all in require-dev so PHPStan can resolve every
  # symbol Classes/ + Configuration/ touch.
  bootstrapFiles:
    - vendor/autoload.php

  # Don't error on unmatched ignored errors during baseline rebuilds.
  reportUnmatchedIgnoredErrors: false
  ignoreErrors:
    -
      identifier: missingType.iterableValue
#includes:
#  - phpstan-baseline.neon
