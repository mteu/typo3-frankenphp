{
    "name": "ochorocho/frankenphp",
    "type": "typo3-cms-extension",
    "description": "FrankenPHP worker mode support for TYPO3",
    "license": "GPL-2.0-or-later",
    "require": {
        "typo3/cms-core": "^14.3 || 15.*@dev",
        "helhum/dotenv-connector": "^3.2",
        "cweagans/composer-patches": "^1.7"
    },
    "require-dev": {
        "composer/composer": "^2.7",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^1.12",
        "typo3/cms-backend": "^14.3",
        "typo3/cms-dashboard": "^14.3",
        "typo3/coding-standards": "^0.8"
    },
    "suggest": {
        "typo3/cms-dashboard": "Required for the live Prometheus metrics dashboard widget — without it the widget gracefully no-ops."
    },
    "autoload": {
        "psr-4": {
            "Ochorocho\\FrankenPhp\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "frankenphp"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": false,
            "typo3/class-alias-loader": true,
            "helhum/dotenv-connector": true,
            "cweagans/composer-patches": true
        }
    }
}
